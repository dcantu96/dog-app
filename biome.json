{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**"]
	},
	"formatter": {
		"enabled": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"quoteStyle": "single"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"correctness": {
				"noUnusedImports": {
					"level": "warn",
					"fix": "safe",
					"options": {}
				},
				"noUnusedVariables": {
					"level": "warn",
					"fix": "safe",
					"options": {}
				},
				"noUnusedFunctionParameters": {
					"level": "warn",
					"fix": "safe",
					"options": {}
				}
			},
			"style": {
				"useConsistentObjectDefinitions": {
					"level": "error",
					"fix": "safe",
					"options": {
						"syntax": "shorthand"
					}
				}
			},
			"nursery": {
				"useSortedClasses": {
					"level": "warn",
					"fix": "safe",
					"options": {
						"functions": ["clsx", "cva", "cn"]
					}
				}
			},
			"recommended": true
		}
	}
}
